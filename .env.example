# ==============================================================================
# 环境变量示例（复制为 .env 并填值）
#
#   cp .env.example .env
#
# 当前应用通过 viper 读取 configs/gin-enterprise-template-apiserver.yaml；
# 如果你希望改为通过环境变量注入
# 敏感字段，可以在 cmd/.../app/server.go 中加入：
#
#   viper.SetEnvPrefix("APP")
#   viper.AutomaticEnv()
#   viper.SetEnvKeyReplacer(strings.NewReplacer(".", "_", "-", "_"))
#
# 之后所有 APP_JWT_SECRET 之类的环境变量会自动覆盖 yaml 中对应字段。
# ==============================================================================

# ----- JWT -----
# 生成命令：openssl rand -hex 32
APP_JWT_SECRET=
APP_JWT_ACCESS_EXPIRATION=2h
APP_JWT_REFRESH_EXPIRATION=168h

# ----- HTTP -----
APP_HTTP_ADDR=0.0.0.0:5555

# ----- PostgreSQL -----
APP_POSTGRESQL_ADDR=127.0.0.1:5432
APP_POSTGRESQL_DATABASE=template
APP_POSTGRESQL_USERNAME=postgres
APP_POSTGRESQL_PASSWORD=

# ----- Redis -----
APP_REDIS_ADDR=127.0.0.1:6379
APP_REDIS_PASSWORD=
APP_REDIS_DATABASE=0

# ----- OpenTelemetry -----
APP_OTEL_ENDPOINT=127.0.0.1:4327
APP_OTEL_SERVICE_NAME=gin-enterprise-template-apiserver
APP_OTEL_OUTPUT_MODE=classic
APP_OTEL_LEVEL=info
